{
  "run_mode": "python_replay_gate",
  "event_clock": "bar_close",
  "inference_transport": "direct_python",
  "inference_endpoint": "tcp://127.0.0.1:5555",
  "max_inference_ms": 50,
  "deterministic_seed": 42,
  "parallelism": {
    "enabled": false,
    "units": "pair_tf",
    "max_workers": 8,
    "notes": "Disabled by default for deterministic replay. Enable for speed after determinism verified."
  },
  "trade_simulation": {
    "allow_short": true,
    "allow_long": true,
    "position_model": "single_position_per_pair_tf",
    "fill_model": "next_bar_open",
    "cooldown_bars_after_exit": 1
  },
  "gating": {
    "require_enabled_models_nonzero": true,
    "hostile_regime_forces_flat": true
  },
  "risk_engine": {
    "enabled": true,
    "policy_path": "risk/config/risk_policy.json"
  },
  "outputs": {
    "write_parquet": true,
    "write_json": true,
    "run_id_format": "UTC_ISO"
  },
  "tf_roles": {
    "H1":  {"role": "TRADE_ENABLED",  "description": "Primary execution TF"},
    "M30": {"role": "TRADE_ENABLED",  "description": "Secondary execution TF"},
    "M15": {"role": "CONFIRM_ONLY",   "description": "Signal confirmer, no independent trades"},
    "M5":  {"role": "CONFIRM_ONLY",   "description": "Signal confirmer, cost-negative everywhere"}
  },
  "gate_criteria": {
    "min_pf_base_plus_25": 1.15,
    "max_dd_pct": 5.0,
    "max_nan_rate": 0.0,
    "max_schema_violations": 0,
    "max_inference_error_rate": 0.0001,
    "min_ledger_coverage": 1.0,
    "notes": "All criteria must pass under BASE_PLUS_25 scenario before MT5 paper trading is authorized."
  }
}
